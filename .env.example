NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# Replica Set обязателен — Mongoose использует транзакции при создании Conversation + membership
MONGO_URI=mongodb://localhost:27017/flare?replicaSet=rs0&directConnection=true

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

JWT_ACCESS_SECRET=change_me_please_at_least_16_chars
JWT_REFRESH_SECRET=change_me_too_at_least_16_characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Список origin через запятую, например: http://localhost:5173,https://useflare.dev
CORS_ORIGIN=http://localhost:5173

THROTTLE_TTL=60
THROTTLE_LIMIT=60
